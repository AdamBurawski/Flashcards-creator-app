---
// Header.astro - Komponent nagłówka z obsługą stanu autentykacji
import AuthMenu from "./auth/AuthMenu";

// Pobierz dane użytkownika z locals (przyda się tylko dla początkowego renderowania)
const { user } = Astro.locals;
const isAuthenticated = !!user;
---

<header class="sticky top-0 z-40 w-full border-b border-white/60 bg-white/75 backdrop-blur-lg">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6">
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-full border border-indigo-100 bg-white px-3 py-1.5 text-sm font-semibold text-slate-800 shadow-sm transition hover:border-indigo-200 hover:shadow"
    >
      <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-indigo-100 text-indigo-700">🧠</span>
      Flashcards Creator
    </a>

    <nav class="flex items-center gap-1 sm:gap-2">
      <a
        href="/"
        class="rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-100 hover:text-slate-900"
      >
        Strona główna
      </a>
      {
        isAuthenticated && (
          <a
            href="/generate"
            class="rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-100 hover:text-slate-900"
          >
            Generowanie
          </a>
        )
      }
      {
        isAuthenticated && (
          <a
            href="/collections"
            class="rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-100 hover:text-slate-900"
          >
            Kolekcje
          </a>
        )
      }
      {
        isAuthenticated && (
          <a
            href="/english"
            class="rounded-lg bg-indigo-50 px-3 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-100"
          >
            🇬🇧 Angielski
          </a>
        )
      }

      <!-- Używamy komponentu React do obsługi stanu logowania -->
      <AuthMenu client:load initialIsAuthenticated={isAuthenticated} />
    </nav>
  </div>
</header>
